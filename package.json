{
  "name": "shorebird-docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/starlight": "^0.38.3",
    "@astrojs/starlight-tailwind": "^5.0.0",
    "@lavamoat/preinstall-always-fail": "^3.0.0",
    "astro": "^6.1.8",
    "sharp": "^0.34.5",
    "starlight-auto-sidebar": "^0.2.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@lavamoat/allow-scripts": "^5.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "starlight-links-validator": "^0.23.0"
  },
  "prettier": {
    "printWidth": 80,
    "proseWrap": "always"
  },
  "lavamoat": {
    "allowScripts": {
      "@lavamoat/preinstall-always-fail": false,
      "astro>esbuild": false,
      "sharp": false,
      "astro>vite>esbuild": false
    }
  }
}
